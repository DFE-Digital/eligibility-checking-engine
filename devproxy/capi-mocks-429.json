{
    "$schema": "https://raw.githubusercontent.com/dotnet/dev-proxy/main/schemas/v0.24.0/mockresponseplugin.schema.json",
    "mocks": [
        {
            "request": {
                "url": "https://fake-capi.dwp.gov.uk/MoqDWP/token",
                "method": "POST"
            },
            "response": {
                "statusCode": 200,
                "body": {
                    "access_token": "mock-token",
                    "expires_in": 3600,
                    "token_type": "Bearer"
                }
            }
        },
        {
            "request": {
                "url": "https://fake-capi.dwp.gov.uk/v2/citizens/match",
                "method": "POST"
            },
            "response": {
                "statusCode": 429,
                "body": {
                    "errors": [
                        {
                            "code": "429",
                            "detail": "Rate limit exceeded",
                            "id": "test-429",
                            "status": "429",
                            "title": "Too Many Requests"
                        }
                    ]
                }
            }
        }
    ]
}
